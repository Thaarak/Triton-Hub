# Flask
FLASK_SECRET_KEY=change-me-in-production
# OAuth callback and signed tokens must use the same secret

# Frontend — Next.js dev app (OAuth redirect after sign-in goes here)
FRONTEND_URL=http://localhost:3000

# CORS — must include the Next origin (comma-separated if you add more)
CORS_ORIGINS=http://localhost:3000

# Supabase (service role key required for admin create user / profiles)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Google OAuth (Web application client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Cloud Console authorized redirect URIs
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
